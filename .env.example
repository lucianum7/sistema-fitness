DATABASE_URL="postgresql://sistema-fitness:${POSTGRES_PASSWORD}@postgres:5432/sistema-fitness?schema=public"
POSTGRES_USER="sistema-fitness"
POSTGRES_PASSWORD="troque-esta-senha"
POSTGRES_DB="sistema-fitness"
SESSION_SECRET="troque-por-uma-chave-com-32-caracteres-ou-mais"
ADMIN_EMAIL="admin@seudominio.com"
ADMIN_INITIAL_PASSWORD="troque-por-uma-senha-forte-unica"
APP_URL="https://sistema-fitness.seudominio.com"
# E-MAIL (verificação de conta e recuperação de senha)
# O envio só funciona com UM remetente configurado. Prioridade: RESEND_API_KEY > SMTP.
# Sem nenhum, em produção o envio falha; em dev o link vira uma "notificação dev".
#
# Opção A (recomendada) — provedor transacional via API:
#   Crie conta no Resend (resend.com), verifique o domínio com SPF + DKIM no DNS,
#   gere a API key e preencha RESEND_API_KEY/RESEND_FROM. Zero servidor de e-mail.
RESEND_API_KEY=""
RESEND_FROM="Sistema Fitness <no-reply@seudominio.com>"
#
# Opção B — SMTP (Brevo, Amazon SES, ou e-mail do domínio na Hostinger):
#   Ex. Brevo: SMTP_HOST="smtp-relay.brevo.com" SMTP_PORT="587"
#   Ex. Hostinger: SMTP_HOST="smtp.hostinger.com" SMTP_PORT="465"
#   Porta 465 = SSL; 587 = STARTTLS. Configure SPF + DKIM do domínio para não cair em spam.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Sistema Fitness <no-reply@seudominio.com>"
MERCADO_PAGO_PUBLIC_KEY=""
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_CLIENT_ID=""
MERCADO_PAGO_CLIENT_SECRET=""
MERCADO_PAGO_WEBHOOK_SECRET=""
MERCADO_PAGO_BACK_URL="https://sistema-fitness.seudominio.com/configuracoes"
BACKUP_DIR="/app/backups"
BACKUP_RETENTION_DAYS="14"
